rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // AUTH & ROLE HELPER FUNCTIONS
    // ========================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAnonymous() {
      return false; // TOTAL LOCKDOWN: Anonymous users are never allowed
    }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "none"};
    }
    
    function hasRole(role) {
      return isSignedIn() && !isAnonymous() && getUserData().role == role;
    }
    
    // Role Hierarchy
    function isOwnerAdmin() {
      return hasRole('owneradmin');
    }
    
    function isAdmin() {
      return hasRole('admin') || isOwnerAdmin();
    }
    
    function isStaff() {
      return hasRole('staff') || isAdmin();
    }

    function isEmploy() {
      return hasRole('employ');
    }
    
    // New pillar roles with lead-access (GROW, OPERATIONS, SUPPORT) + Legacy Support
    function isGrowthRole() {
      return isSignedIn() && !isAnonymous() && getUserData().role in
        ['GROW_L0','GROW_L1','GROW_L2','GROW_L3','GROW_L4','GROW_L5',
         'GROWTH_L0','GROWTH_L1','GROWTH_L2','GROWTH_L3','GROWTH_L4','GROWTH_L5'];
    }

    function isOperationsRole() {
      return isSignedIn() && !isAnonymous() && getUserData().role in
        ['OPS_L0','OPS_L1','OPS_L2','OPS_L3','OPS_L4','OPS_L5',
         'ENG_L0','ENG_L1','ENG_L2','ENG_L3','ENG_L4','ENG_L5',
         'CLOUD_L0','CLOUD_L1'];
    }

    function isSupportRole() {
      return isSignedIn() && !isAnonymous() && getUserData().role in
        ['SUP_L0','SUP_L1','SUP_L2','SUP_L3',
         'CS_L0','CS_L1','CS_L2','CS_L3'];
    }

    // Any authenticated employee pillar with lead access
    function isAnyEmployee() {
      return isSignedIn() && (getUserData().role in ['staff', 'admin', 'owneradmin', 'employ']
         || isGrowthRole() || isOperationsRole() || isSupportRole());
    }

    // Roles that can access chat/messages (GROW, OPS_L4 Solutions Architect, SUPPORT)
    function canAccessChats() {
      return isAdmin() || hasRole('staff') || isEmploy() || isGrowthRole() || isSupportRole()
        || (isSignedIn() && !isAnonymous() && (getUserData().role == 'OPS_L4' || getUserData().role == 'ENG_L4'));
    }

    function canAccessWahaInbox() {
      return canAccessChats();
    }

    function canReadWahaChatFields(data) {
      return isAdmin()
        || (canAccessChats()
            && (data.assignedTo == null || data.assignedTo == request.auth.uid));
    }
    
    function isClient() {
      return hasRole('client');
    }
    
    // ========================================
    // VALIDATION HELPER FUNCTIONS
    // ========================================
    
    // Check if field exists and is a string up to max length
    function isString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }
    
    // Check if field exists and is a list
    function isList(val, maxItems) {
      return val is list && val.size() <= maxItems;
    }

    // ========================================
    // LEADS (PROSPECTOS) - Public Lead Capture
    // ========================================
    match /leads/{leadId} {
      
      // Strict structural validation for tracking drafts
      function isValidLeadDraft() {
        let data = request.resource.data;
        let isDraft = data.status_flow.current == 'LEAD_DRAFT';
        
        // Optional structural checking to prevent massive object injection
        let hasValidBase = data.keys().hasOnly(['kpis', 'audit_logs', 'data', 'lead_id', 'status_flow', 'source_attribution', 'priority', 'turnstile_token', 'name', 'email', 'phone', 'company', 'role', 'website', 'objectives', 'stage', 'timeline', 'investment_level', 'impact', 'decision_maker', 'file_url']);
        
        // Prevent massive strings in tracking kpis
        let validKpis = !('kpis' in data) || (data.kpis is map);
        
        // Ensure form data arrays and strings are not abused if present
        let validData = !('data' in data) || (
          data.data is map &&
          (!('name' in data.data) || isString(data.data.name, 0, 100)) &&
          (!('email' in data.data) || isString(data.data.email, 0, 100)) &&
          (!('impact' in data.data) || isString(data.data.impact, 0, 3000))
        );

        return isDraft && hasValidBase && validKpis && validData;
      }

      // BLOCK direct public access
      // Leads can be created by authenticated staff/employees via client SDK
      allow create: if isAnyEmployee();
      
      // Prevent open scraping
      allow get: if isAnyEmployee();
      allow list: if isAnyEmployee();
      
      // Only employees and above can update leads
      allow update: if isAnyEmployee();
      
      // Only admins can delete leads
      allow delete: if isAdmin();
    }
    
    // ========================================
    // INTERACTIONS - Analytics & Tracking
    // ========================================
    match /interactions/{interactionId} {
      
      // Strict structural validation for tracking events
      function isValidInteraction() {
        let data = request.resource.data;
        let hasValidBase = data.keys().hasOnly(['event_type', 'timestamp', 'session_id', 'lead_id', 'metadata', 'url']);
        let validFields = (
          isString(data.event_type, 1, 50) &&
          isString(data.session_id, 1, 100) &&
          (data.lead_id == null || isString(data.lead_id, 1, 100)) &&
          isString(data.url, 0, 1000) &&
          (!('metadata' in data) || data.metadata is map)
        );
        return hasValidBase && validFields;
      }

      // Anyone can log strictly validated tracking events
      // Only allow creation via Admin SDK if we want total lockdown
      // Or keep it highly restricted if we want client-side non-critical events
      allow create: if false; 
      
      // Only staff can read analytics data
      allow read: if isStaff();
      
      // Only admins can modify or delete tracking data
      allow update, delete: if isAdmin();
    }

    // ========================================
    // SERVICES - Portfolio & Service Catalog
    // ========================================
    match /services/{serviceId} {
      // Publicly readable (for website portfolio display)
      allow read: if true;
      
      // Only admins can create, update, or delete services
      allow write: if isAdmin();
    }

    // ========================================
    // BOOKINGS - Appointment Reservations
    // ========================================
    match /bookings/{bookingId} {
      
      function isValidBooking() {
         let data = request.resource.data;
         let hasValidBase = data.keys().hasOnly(['id', 'customerName', 'customerEmail', 'customerPhone', 'date', 'time', 'services', 'totalPrice', 'status', 'address', 'history', 'userId', 'createdAt', 'updatedAt']);
         
         let validFields = (
           isString(data.customerName, 1, 100) &&
           isString(data.customerEmail, 5, 100) &&
           isString(data.customerPhone, 5, 20) &&
           isString(data.date, 8, 20) &&
           isString(data.time, 4, 20) &&
           isList(data.services, 10) &&
           data.totalPrice is number &&
           data.status in ['pending', 'confirmed', 'attended', 'cancelled']
         );
         
         return hasValidBase && validFields;
      }

      // Anyone can create strictly validated bookings
      allow create: if isValidBooking();
      
      // Staff and all employees can read all bookings
      // Staff and all employees can read all bookings
      allow read: if isAnyEmployee();
      
      // Staff and all employees can update booking status and details
      allow update: if isAnyEmployee();
      
      // Only admins can delete bookings
      allow delete: if isAdmin();
    }

    // ========================================
    // USERS - User Profiles & Roles
    // ========================================
    match /users/{userId} {
      // CRITICAL: Users MUST be able to read their own document
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Additional read permission for all employee roles to view users
      // This is necessary for the management panel and assignment dropdowns
      allow list, get: if isSignedIn() && !isAnonymous() && isAnyEmployee();
      
      // Users can create their own profile during registration
      // Admins can create any user profile
      allow create: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      // Users can update their own profile (EXCEPT their role field to prevent self-promotion)
      // Admins can update any profile except owners, and cannot promote to owner
      // Owners (OwnerAdmin) can update any profile without restrictions
      allow update: if (isSignedIn() && request.auth.uid == userId && request.resource.data.role == resource.data.role)
                    || (isOwnerAdmin())
                    || (isAdmin() && resource.data.role != 'owneradmin' && request.resource.data.role != 'owneradmin');
      
      // Only owner admins can delete users
      allow delete: if isOwnerAdmin();
    }

    // ========================================
    // SETTINGS - Business Configuration
    // ========================================
    match /settings/{settingId} {
      // Publicly readable (for business hours, availability calculations)
      allow read: if true;
      
      // Only admins can modify business settings
      allow write: if isAdmin();
    }
    
    // ========================================
    // DISABLED_SLOTS - Availability Management
    // ========================================
    match /disabled_slots/{slotId} {
      // Accessible to staff only for management
      allow read, write: if isStaff();
    }

    // ========================================
    // WAHA — sesiones multinúmero (metadatos)
    // ========================================
    match /waha_sessions/{sessionId} {
      allow read: if isSignedIn() && canAccessWahaInbox();
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // WAHA — chats (WhatsApp)
    // ========================================
    match /waha_chats/{chatId} {
      allow read: if isSignedIn() && canReadWahaChatFields(resource.data);

      allow create: if false;

      allow delete: if isAdmin();

      function wahaAgentPatchKeys() {
        return request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['assignedTo', 'ticketValue', 'updatedAt']);
      }

      function wahaAgentPatchValid() {
        let before = resource.data;
        let after = request.resource.data;
        return (before.assignedTo == null && (after.assignedTo == null || after.assignedTo == request.auth.uid)) ||
               (before.assignedTo == request.auth.uid && (after.assignedTo == request.auth.uid || after.assignedTo == null));
      }

      allow update: if isAdmin()
        || (isSignedIn() && canAccessChats()
            && wahaAgentPatchKeys() && wahaAgentPatchValid());
    }

    match /waha_chats/{chatId}/messages/{messageId} {
      function parentWahaChat() {
        return get(/databases/$(database)/documents/waha_chats/$(chatId)).data;
      }

      allow read: if isSignedIn() && canReadWahaChatFields(parentWahaChat());

      allow create, update, delete: if false;
    }
  }
}
