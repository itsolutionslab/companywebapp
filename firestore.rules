rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // AUTH & ROLE HELPER FUNCTIONS
    // ========================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAnonymous() {
      return false; // TOTAL LOCKDOWN: Anonymous users are never allowed
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && !isAnonymous() && getUserData().role == role;
    }
    
    // Role Hierarchy (from highest to lowest privilege)
    function isOwnerAdmin() {
      return hasRole('owneradmin');
    }
    
    function isAdmin() {
      return hasRole('admin') || isOwnerAdmin();
    }
    
    function isStaff() {
      return hasRole('staff') || isAdmin();
    }
    
    function isClient() {
      return hasRole('client');
    }
    
    // ========================================
    // VALIDATION HELPER FUNCTIONS
    // ========================================
    
    // Check if field exists and is a string up to max length
    function isString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }
    
    // Check if field exists and is a list
    function isList(val, maxItems) {
      return val is list && val.size() <= maxItems;
    }

    // ========================================
    // LEADS (PROSPECTOS) - Public Lead Capture
    // ========================================
    match /leads/{leadId} {
      
      // Strict structural validation for tracking drafts
      function isValidLeadDraft() {
        let data = request.resource.data;
        let isDraft = data.status_flow.current == 'LEAD_DRAFT';
        
        // Optional structural checking to prevent massive object injection
        let hasValidBase = data.keys().hasOnly(['kpis', 'audit_logs', 'data', 'lead_id', 'status_flow', 'source_attribution', 'priority', 'turnstile_token', 'name', 'email', 'phone', 'company', 'role', 'website', 'objectives', 'stage', 'timeline', 'investment_level', 'impact', 'decision_maker', 'file_url']);
        
        // Prevent massive strings in tracking kpis
        let validKpis = !('kpis' in data) || (data.kpis is map);
        
        // Ensure form data arrays and strings are not abused if present
        let validData = !('data' in data) || (
          data.data is map &&
          (!('name' in data.data) || isString(data.data.name, 0, 100)) &&
          (!('email' in data.data) || isString(data.data.email, 0, 100)) &&
          (!('impact' in data.data) || isString(data.data.impact, 0, 3000))
        );

        return isDraft && hasValidBase && validKpis && validData;
      }

      // BLOCK PUBLIC ACCESS
      // Leads must ONLY be created via the secure API (Admin SDK)
      allow create: if false;
      
      // Prevent open scraping
      allow get: if isStaff();
      allow list: if isStaff();
      
      // Only staff can update leads.
      allow update: if isStaff();
      
      // Only admins can delete leads
      allow delete: if isAdmin();
    }
    
    // ========================================
    // INTERACTIONS - Analytics & Tracking
    // ========================================
    match /interactions/{interactionId} {
      
      // Strict structural validation for tracking events
      function isValidInteraction() {
        let data = request.resource.data;
        let hasValidBase = data.keys().hasOnly(['event_type', 'timestamp', 'session_id', 'lead_id', 'metadata', 'url']);
        let validFields = (
          isString(data.event_type, 1, 50) &&
          isString(data.session_id, 1, 100) &&
          (data.lead_id == null || isString(data.lead_id, 1, 100)) &&
          isString(data.url, 0, 1000) &&
          (!('metadata' in data) || data.metadata is map)
        );
        return hasValidBase && validFields;
      }

      // Anyone can log strictly validated tracking events
      // Only allow creation via Admin SDK if we want total lockdown
      // Or keep it highly restricted if we want client-side non-critical events
      allow create: if false; 
      
      // Only staff can read analytics data
      allow read: if isStaff();
      
      // Only admins can modify or delete tracking data
      allow update, delete: if isAdmin();
    }

    // ========================================
    // SERVICES - Portfolio & Service Catalog
    // ========================================
    match /services/{serviceId} {
      // Publicly readable (for website portfolio display)
      allow read: if true;
      
      // Only admins can create, update, or delete services
      allow write: if isAdmin();
    }

    // ========================================
    // BOOKINGS - Appointment Reservations
    // ========================================
    match /bookings/{bookingId} {
      
      function isValidBooking() {
         let data = request.resource.data;
         let hasValidBase = data.keys().hasOnly(['id', 'customerName', 'customerEmail', 'customerPhone', 'date', 'time', 'services', 'totalPrice', 'status', 'address', 'history', 'userId', 'createdAt', 'updatedAt']);
         
         let validFields = (
           isString(data.customerName, 1, 100) &&
           isString(data.customerEmail, 5, 100) &&
           isString(data.customerPhone, 5, 20) &&
           isString(data.date, 8, 20) &&
           isString(data.time, 4, 20) &&
           isList(data.services, 10) &&
           data.totalPrice is number &&
           data.status in ['pending', 'confirmed', 'attended', 'cancelled']
         );
         
         return hasValidBase && validFields;
      }

      // Anyone can create strictly validated bookings
      allow create: if isValidBooking();
      
      // Staff can read all bookings
      allow read: if isStaff();
      
      // Staff can update booking status and details
      allow update: if isStaff();
      
      // Only admins can delete bookings
      allow delete: if isAdmin();
    }

    // ========================================
    // USERS - User Profiles & Roles
    // ========================================
    match /users/{userId} {
      // CRITICAL: Users MUST be able to read their own document BEFORE role checking
      // Otherwise getUserData() in helper functions creates a circular dependency
      // Staff can also read all user profiles (but this check happens AFTER self-read)
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Additional read permission for staff to view all users
      // This is separate to avoid circular dependency
      allow read: if isSignedIn() && !isAnonymous() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['staff', 'admin', 'owneradmin'];
      
      // Users can create their own profile during registration
      // Admins can create any user profile
      allow create: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      // Users can update their own profile (except role field)
      // Admins can update any profile including roles
      allow update: if (isSignedIn() && request.auth.uid == userId && request.resource.data.role == resource.data.role)
                    || isAdmin();
      
      // Only owner admins can delete users
      allow delete: if isOwnerAdmin();
    }

    // ========================================
    // SETTINGS - Business Configuration
    // ========================================
    match /settings/{settingId} {
      // Publicly readable (for business hours, availability calculations)
      allow read: if true;
      
      // Only admins can modify business settings
      allow write: if isAdmin();
    }
    
    // ========================================
    // DISABLED_SLOTS - Availability Management
    // ========================================
    match /disabled_slots/{slotId} {
      // Accessible to staff only for management
      allow read, write: if isStaff();
    }
  }
}
