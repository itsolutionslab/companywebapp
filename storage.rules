rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ========================================
    // AYUDAS DE AUTENTICACIÓN Y ROLES
    // ========================================
    function isSignedIn() { return request.auth != null; }
    function isStaff() { 
    	return isSignedIn() && !isAnonymous() && 
             (request.auth.token.role in ['staff', 'admin', 'owneradmin', 'employ']);
    }
    function isAdmin() { return request.auth.token.role in ['admin', 'owneradmin']; }
    
    function isAnonymous() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }
    
    function getUserRole() {
      return request.auth.token.role;
    }
    
    function hasRole(role) {
      return isSignedIn() && !isAnonymous() && getUserRole() == role;
    }

    // ========================================
    // VALIDACIÓN DE ARCHIVOS (PDF e Imágenes solamente)
    // ========================================
    function isValidImage() {
      return request.resource.contentType.matches('(?i)image/.*');
    }

    function isValidDocument() {
      return request.resource.contentType.matches('(?i)application/.*pdf.*')
      	|| request.resource.contentType in ['application/octet-stream', 'application/x-pdf', 'application/x-bzpdf', 'application/x-gzpdf', 'application/pdf-test'];
    }

    function isValidLeadAttachment() {
      return isValidImage() || isValidDocument();
    }
    function hasValidExtension() {
      return request.resource.name.matches('.*\\.(jpg|jpeg|png|webp|pdf)$');
    }

    // ========================================
    // ADJUNTOS DE LEADS - Seguridad Máxima
    // ========================================
    match /leads/{sessionId}/{fileName} {
      // Ya NO son públicos. Solo el staff puede ver los documentos de prospectos.
      allow read: if isStaff();
      
      // Subida pública permitida con validación estricta (Max 5MB)
      allow create: if isValidLeadAttachment() 
                    && request.resource.size < 5 * 1024 * 1024;
      
      allow update, delete: if isStaff();
    }

    // ========================================
    // IMÁGENES DE SERVICIOS
    // ========================================
    match /services/{allPaths=**} {
      allow read: if true;
      allow create: if isAdmin() && isValidImage() && hasValidExtension() && request.resource.size < 3 * 1024 * 1024;
      allow update, delete: if isAdmin();
    }

    // ========================================
    // OTROS (Usuarios y Proyectos)
    // ========================================
    match /users/{userId}/{fileName} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() 
                    && (request.auth.uid == userId || isStaff())
                    && isValidImage()
                    && request.resource.size < 5 * 1024 * 1024;
      allow update, delete: if (isSignedIn() && request.auth.uid == userId) || isStaff();
    }
    
    match /projects/{projectId}/{allPaths=**} {
      allow read: if isStaff() || hasRole('client');
      allow create: if isStaff() 
                    && (isValidImage() || isValidDocument())
                    && request.resource.size < 50 * 1024 * 1024;
      allow update, delete: if isStaff();
    }
  }
}